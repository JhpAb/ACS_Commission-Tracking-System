{
  "name": "ACS - Suivi des créances",
  "dataColors": [
    "#1B2A4A",
    "#E4622D",
    "#2E9E5B",
    "#3B6EA5",
    "#F2A65A",
    "#7C8DA6",
    "#C0392B",
    "#1D6F5C",
    "#8E5A2D",
    "#5B7C99"
  ],
  "good": "#2E9E5B",
  "neutral": "#F2A65A",
  "bad": "#C0392B",
  "maximum": "#1B2A4A",
  "center": "#F2A65A",
  "minimum": "#F5F5F5",
  "background": "#FFFFFF",
  "foreground": "#1B2A4A",
  "tableAccent": "#E4622D",

  "textClasses": {
    "callout": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 32,
      "color": "#1B2A4A"
    },
    "title": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 14,
      "color": "#1B2A4A"
    },
    "header": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 12,
      "color": "#1B2A4A"
    },
    "label": {
      "fontFace": "Segoe UI",
      "fontSize": 10,
      "color": "#3D4B63"
    }
  },

  "visualStyles": {
    "page": {
      "*": {
        "background": [
          { "color": { "solid": { "color": "#FFFFFF" } } }
        ]
      }
    },

    "card": {
      "*": {
        "labels": [
          {
            "color": { "solid": { "color": "#1B2A4A" } },
            "fontSize": 28,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "categoryLabels": [
          {
            "color": { "solid": { "color": "#7C8DA6" } },
            "fontSize": 11
          }
        ]
      }
    },

    "multiRowCard": {
      "*": {
        "dataLabels": [
          { "color": { "solid": { "color": "#1B2A4A" } } }
        ],
        "categoryLabels": [
          { "color": { "solid": { "color": "#7C8DA6" } } }
        ]
      }
    },

    "gauge": {
      "*": {
        "dataColors": [
          { "fill": { "solid": { "color": "#E4622D" } } }
        ],
        "targetLine": [
          { "lineColor": { "solid": { "color": "#1B2A4A" } }, "show": true }
        ]
      }
    },

    "columnChart": {
      "*": {
        "dataPoint": [
          { "fill": { "solid": { "color": "#1B2A4A" } } }
        ]
      }
    },

    "lineChart": {
      "*": {
        "dataPoint": [
          { "fill": { "solid": { "color": "#E4622D" } } }
        ],
        "trend": [
          { "lineColor": { "solid": { "color": "#7C8DA6" } }, "show": true }
        ]
      }
    },

    "pieChart": {
      "*": {
        "dataPoint": [
          { "fill": { "solid": { "color": "#2E9E5B" } } }
        ],
        "legend": [
          { "labelColor": { "solid": { "color": "#1B2A4A" } } }
        ]
      }
    },

    "donutChart": {
      "*": {
        "dataPoint": [
          { "fill": { "solid": { "color": "#2E9E5B" } } }
        ]
      }
    },

    "tableEx": {
      "*": {
        "grid": [
          { "gridVertical": false, "rowPadding": 6 }
        ],
        "columnHeaders": [
          {
            "fontColor": { "solid": { "color": "#FFFFFF" } },
            "backColor": { "solid": { "color": "#1B2A4A" } },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 10
          }
        ],
        "values": [
          {
            "fontColor": { "solid": { "color": "#1B2A4A" } },
            "backColor": { "solid": { "color": "#FFFFFF" } },
            "alternateBackColor": { "solid": { "color": "#F5F7FA" } },
            "fontSize": 10
          }
        ]
      }
    },

    "pivotTable": {
      "*": {
        "columnHeaders": [
          {
            "fontColor": { "solid": { "color": "#FFFFFF" } },
            "backColor": { "solid": { "color": "#1B2A4A" } }
          }
        ],
        "rowHeaders": [
          {
            "fontColor": { "solid": { "color": "#1B2A4A" } },
            "backColor": { "solid": { "color": "#F5F7FA" } }
          }
        ]
      }
    },

    "slicer": {
      "*": {
        "items": [
          {
            "fontColor": { "solid": { "color": "#1B2A4A" } },
            "selectedColor": { "solid": { "color": "#E4622D" } }
          }
        ],
        "header": [
          {
            "fontColor": { "solid": { "color": "#1B2A4A" } },
            "background": { "solid": { "color": "#F5F7FA" } },
            "fontFamily": "Segoe UI Semibold"
          }
        ]
      }
    },

    "kpi": {
      "*": {
        "values": [
          {
            "goalColor": { "solid": { "color": "#7C8DA6" } },
            "goodColor": { "solid": { "color": "#2E9E5B" } },
            "neutralColor": { "solid": { "color": "#F2A65A" } },
            "badColor": { "solid": { "color": "#C0392B" } }
          }
        ]
      }
    }
  }
}
